{
  "name": "haldy",
  "version": "0.3.1",
  "description": "Your codebase, held. GraphRAG-powered codebase intelligence for git repositories.",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/lib.js",
      "types": "./dist/lib.d.ts"
    },
    "./mcp": {
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "hald": "dist/cli.js",
    "haldy": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/ && tsc --noEmit",
    "lint:eslint": "eslint src/ tests/",
    "lint:types": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "preview:scan": "tsx scripts/preview-pretty-scan.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "graphrag",
    "git",
    "knowledge-graph",
    "mcp",
    "institutional-knowledge"
  ],
  "license": "MIT",
  "author": {
    "name": "Gabriel Carvalho",
    "url": "https://github.com/gabrielcarvvlho"
  },
  "files": [
    "dist",
    "bin",
    "skills",
    "hooks",
    ".claude-plugin",
    ".cursor",
    ".cursor-plugin",
    ".opencode",
    ".codex",
    ".mcp.json",
    "gemini-extension.json",
    "GEMINI.md",
    "LICENSE",
    "src/viz/public"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gabrielcarvvlho/hald.git"
  },
  "homepage": "https://github.com/gabrielcarvvlho/hald#readme",
  "bugs": {
    "url": "https://github.com/gabrielcarvvlho/hald/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@google/genai": "^1.0.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "better-sqlite3": "^11.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "dotenv": "^17.3.1",
    "fast-xml-parser": "^4.5.0",
    "graphology": "^0.25.4",
    "graphology-communities-louvain": "^2.0.1",
    "graphology-components": "^1.5.4",
    "graphology-layout-forceatlas2": "^0.10.1",
    "graphology-metrics": "^2.3.0",
    "listr2": "^10.2.1",
    "openai": "^4.80.0",
    "ora": "^8.0.0",
    "p-limit": "^6.0.0",
    "sigma": "^3.0.2",
    "simple-git": "^3.27.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.0.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "tsup": "^8.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.58.0",
    "vitest": "^3.0.0"
  }
}
