{
  "name": "git-oracle",
  "version": "0.1.0",
  "description": "GraphRAG-powered knowledge graph for git repositories",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "git-oracle": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "graphrag",
    "git",
    "knowledge-graph",
    "mcp",
    "institutional-knowledge"
  ],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@google/genai": "^1.0.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "better-sqlite3": "^11.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "fast-xml-parser": "^4.5.0",
    "graphology": "^0.25.4",
    "graphology-communities-louvain": "^2.0.1",
    "graphology-metrics": "^2.3.0",
    "openai": "^4.80.0",
    "ora": "^8.0.0",
    "p-limit": "^6.0.0",
    "simple-git": "^3.27.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
