# Hald — LLM Provider Configuration
# Copy this file to .env and fill in at least one provider key.
# The CLI auto-detects which provider to use based on available keys.
# Priority: Anthropic > OpenAI > Google

# ── Anthropic (Claude) ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── OpenAI (GPT) ────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Google (Gemini) ─────────────────────────────────────────────────────────
GOOGLE_API_KEY=...
# GEMINI_API_KEY=...   # alternative to GOOGLE_API_KEY

# ── Custom endpoint (Ollama, OpenRouter, Azure, etc.) ───────────────────────
# Set alongside the appropriate provider key above.
# HALD_BASE_URL=http://localhost:11434
